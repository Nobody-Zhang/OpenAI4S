"""Library matching: peak-driven selection of the next component from a residual.

The iterative subtraction loop (``loop.search``) calls ``best_next_component``
once per step: it re-detects peaks on the *current residual*, restricts the
library to minerals whose reference peaks coincide with those residual peaks,
and returns the single best-correlating candidate. The loop then NNLS-refits and
subtracts. This is what lets weak/overlapping components emerge once a dominant
phase has been removed.
"""
from __future__ import annotations

import numpy as np

from . import metrics
from .data import Library
from .preprocess import detect_peaks_2nd_deriv


def rank_library(processed: np.ndarray, lib: Library, metric: str = "pearson") -> np.ndarray:
    """Return correlation of the processed target against every library column."""
    fn = metrics.pearson if metric == "pearson" else metrics.cosine
    return np.array([fn(processed, lib.A[:, j]) for j in range(len(lib.names))])


# ---------------------------------------------------------------------------
# Peak-driven candidate pre-filter
# ---------------------------------------------------------------------------
def _reference_peaks(lib: Library, config: dict) -> list:
    """Second-derivative peak positions for every library column.

    Cached on the library object keyed by the peak-detection params so the
    per-mineral peak picking isn't recomputed every loop step.
    """
    key = (config.get("peak_smooth_window", 11), config.get("peak_savgol_poly", 3),
           config.get("peak_prominence_sigma", 3.0), config.get("peak_min_distance_cm", 8.0))
    cache = getattr(lib, "_ref_peak_cache", None)
    if cache is None:
        cache = {}
        setattr(lib, "_ref_peak_cache", cache)
    if key not in cache:
        cache[key] = [detect_peaks_2nd_deriv(lib.A[:, j], lib.grid, config)
                      for j in range(len(lib.names))]
    return cache[key]


def _peak_prefilter(peaks: np.ndarray, lib: Library, config: dict) -> np.ndarray:
    """Indices of library minerals whose reference peaks coincide with the
    detected target peaks. A mineral passes if at least ``peak_min_matches`` of
    its reference peaks fall within ``peak_match_tol_cm`` of some target peak."""
    tol = config.get("peak_match_tol_cm", 8.0)
    min_matches = config.get("peak_min_matches", 1)
    ref_peaks = _reference_peaks(lib, config)
    tgt = np.asarray(peaks, dtype=float)
    allowed = []
    for j, rp in enumerate(ref_peaks):
        if len(rp) == 0:
            continue
        coincident = int(np.sum([np.min(np.abs(tgt - p)) <= tol for p in rp]))
        if coincident >= min_matches:
            allowed.append(j)
    return np.array(allowed, dtype=int)


# ---------------------------------------------------------------------------
# Peak-driven next-component selection (one step of the subtraction loop)
# ---------------------------------------------------------------------------
def best_next_component(residual: np.ndarray, peaks: np.ndarray, lib: Library,
                        config: dict, exclude=()):
    """Pick the single best library component to explain the current residual.

    Candidate pool = minerals whose reference peaks coincide with the residual's
    detected ``peaks`` (when ``peak_prefilter_enabled``); falls back to the full
    library if the pre-filter would leave nothing. Already-selected indices in
    ``exclude`` are removed. Returns ``(index, correlation)`` of the highest
    correlating candidate, or ``(None, 0.0)`` if the pool is empty.
    """
    metric = metrics.pearson if config["match_metric"] == "pearson" else metrics.cosine
    exclude = set(int(e) for e in exclude)

    pool = None
    if config.get("peak_prefilter_enabled", True) and peaks is not None and len(peaks):
        allowed = _peak_prefilter(peaks, lib, config)
        if len(allowed):
            pool = [int(a) for a in allowed]
    if pool is None:
        pool = list(range(len(lib.names)))
    pool = [j for j in pool if j not in exclude]
    if not pool:
        return None, 0.0

    scores = {j: metric(residual, lib.A[:, j]) for j in pool}
    best = max(scores, key=scores.get)
    return int(best), float(scores[best])
